<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Nisablossom" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- 1. Buat status bar menjadi transparan -->
        <item name="android:statusBarColor">@android:color/transparent</item>

        <!-- 2. Biarkan isi layout XML naik menembus status bar -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- 3. Buat ikon status bar otomatis menyesuaikan (gelap di layar terang, putih di layar gelap) -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

    </style>

    <style name="Theme.Nisablossom" parent="Base.Theme.Nisablossom" />
</resources>